<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude specific shared preferences that contain GCM registration Id -->
        <exclude
            domain="sharedpref"
            path="gcm.xml" />
        <!-- Exclude the app's database directory -->
        <exclude
            domain="database"
            path="track_recorder_database" />
    </cloud-backup>
    <device-transfer>
        <!-- Exclude specific shared preferences that contain GCM registration Id -->
        <exclude
            domain="sharedpref"
            path="gcm.xml" />
        <!-- Exclude the app's database directory -->
        <exclude
            domain="database"
            path="track_recorder_database" />
    </device-transfer>
</data-extraction-rules>